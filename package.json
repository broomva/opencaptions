{
  "name": "opencaptions",
  "private": true,
  "version": "0.1.0",
  "description": "Feel the film. Render the intent. Open-source CWI caption generation pipeline.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
